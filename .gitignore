# macOS Finder and filesystem metadata
.DS_Store
.AppleDouble
.LSOverride
._*

# Xcode user state and local build output
DerivedData/
Build/
build/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xcresult
*.xcresult/
*.xcactivitylog
*.xccheckout
*.moved-aside

# Archives, debug symbols, and exported app artifacts
*.xcarchive
*.dSYM/
*.dSYM.zip
*.ipa
*.pkg
*.dmg

# Swift Package Manager local caches.
# Keep Package.resolved tracked when it belongs to the project workspace so a
# fresh clone resolves the same package revisions as CI.
.build/
.swiftpm/
Packages/

# Playgrounds and temporary timelines
timeline.xctimeline
playground.xcworkspace
*.playground/playground.xcworkspace/

# CocoaPods and Carthage output, if either is used locally.
# Podfile.lock and Cartfile.resolved should be reviewed intentionally if these
# dependency managers are introduced later.
Pods/
Carthage/Build/
Carthage/Checkouts/

# Fastlane generated output
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# Local editor and agent state
.claude/
.codex/
.cursor/
.idea/
.vscode/
.xcodebuildmcp/

# Secrets, signing material, and local configuration
.env
.env.*
*.env
*.p12
*.cer
*.mobileprovision
*.provisionprofile
*.xcconfig.local
*.local.xcconfig

# Logs and temporary files
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# Generated snapshot baselines: review and commit intentional baselines only.
KeiBATests/BA/Snapshot/Baselines/*-actual.png
