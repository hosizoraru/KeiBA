    "ba.settings.app.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow System keeps KeiBAOS aligned with the device. Language updates interface text; appearance switches the app between system, light, and dark modes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认跟随系统，让 KeiBAOS 与设备保持一致。语言会切换界面文本；外观会在跟随系统、浅色和深色之间切换。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムに従うとKeiBAOSはデバイス設定に合わせます。言語は画面文言を切り替え、外観はシステム・ライト・ダークを切り替えます。"
          }
        }
      }
    },
