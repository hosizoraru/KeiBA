    "ba.sheet.edit.identity.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the nickname and Friend Code from your in-game ID card. Server-specific identity keeps each server separate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这里填写游戏内 ID 卡上的昵称和好友码；开启按服独立后，每个服务器会分别保存。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゲーム内IDカードのニックネームとフレンドコードを入力します。サーバー別IDを有効にすると、サーバーごとに個別保存します。"
          }
