    "ba.overview.ap.editor.current.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current AP is the Action Point value shown in game. Saving it starts recovery timing from now."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 AP 对应游戏内行动点数；保存后会从现在开始重新计算自然恢复。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のAPはゲーム内に表示されるAction Pointです。保存すると、今から回復時間を計算します。"
          }
        }
      }
    },
    "ba.overview.ap.editor.footer": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current AP resets the recovery baseline. Limit and threshold are saved for the selected server."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 AP 会重置恢复基线，上限和阈值会保存到当前服务器。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のAPを保存すると回復基準がリセットされます。上限と通知しきい値は選択中のサーバーに保存されます。"
          }
        }
      }
    },
    "ba.overview.ap.editor.footer.format": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current AP resets the recovery baseline. AP limit is %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 AP 会重置恢复基线。AP 上限为 %@。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のAPを保存すると回復基準がリセットされます。AP上限は%@です。"
          }
        }
      }
    },
    "ba.overview.ap.editor.rules.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AP limit is your current in-game maximum. The threshold controls when AP reminders become useful."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AP 上限对应游戏内当前最大体力；阈值用于决定 AP 提醒触发时机。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AP上限はゲーム内の現在最大値です。しきい値はAP通知を出すタイミングに使います。"
          }
        }
      }
    },
